# ─────────────────────────────────────────────
#  RustLink Bot — environment variables
#  Copy this file to ".env" and fill in your values.
#  NEVER commit your real .env (it is gitignored).
# ─────────────────────────────────────────────

# ── Discord ──────────────────────────────────
# Bot token from https://discord.com/developers/applications -> Bot -> Token
DISCORD_TOKEN=your-bot-token-here
# Application (client) ID, same page -> General Information -> Application ID
DISCORD_CLIENT_ID=your-application-id
# Optional: register slash commands INSTANTLY to one guild while developing.
# Leave empty to register commands GLOBALLY (can take up to ~1h to appear).
DISCORD_GUILD_ID=

# ── API backend ──────────────────────────────
# Port the API listens on. Cloud hosts (Railway/Render) inject their own PORT
# at runtime — it is read FIRST, so you don't set anything there. API_PORT is
# only the local-dev fallback.
API_PORT=3000
# Shared secret the Rust/Oxide plugin must send with each webhook
# (HTTP header: x-webhook-secret). Leave EMPTY in local dev to disable
# auth so you can test with curl/Postman. Always set it in production.
WEBHOOK_SECRET=change-me
# Separate secret for ADMIN operations (DELETE /servers/:name), sent as the
# x-admin-secret header. Kept apart from WEBHOOK_SECRET (which every Rust server
# operator gets) so a plugin secret can never delete data. Empty = admin auth off.
ADMIN_SECRET=change-me-too

# ── Rate limiting (per IP) ───────────────────
# Defence-in-depth on the public API. Defaults: 300 requests / 60s per IP.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# ── Database ─────────────────────────────────
# SQLite file path (created automatically). Switch to PostgreSQL later if needed.
# In production with a mounted volume, point this at the volume, e.g.
#   DATABASE_PATH=/data/rustlink.sqlite
DATABASE_PATH=./data/rustlink.sqlite

# ── Rust+ companion (Phase 7) ────────────────
# The Rust+ socket manager. Per-server credentials (ip/port/steamId/playerToken) are
# NOT set here — they live in the DB, added via the /pair Discord command (admin-only).
# These vars only tune the manager. Kill-switch: set to "false" to disable it entirely.
RUSTPLUS_ENABLED=true
# Reconnect backoff bounds (ms) and per-request timeout (ms).
RUSTPLUS_RECONNECT_MIN_MS=2000
RUSTPLUS_RECONNECT_MAX_MS=60000
RUSTPLUS_REQUEST_TIMEOUT_MS=10000
# Anti-spam cooldown (ms) per in-game "!" command, per server: a command runs at most
# once per window no matter how many teammates fire it. Set 0 to disable cooldowns.
RUSTPLUS_CMD_COOLDOWN_MS=5000

# ── FCM auto-pairing (Phase 7.2) ─────────────
# Listen for Rust+ "Pair with Server" push notifications and create pairings
# automatically (no manual /pair). The Steam login (fcm-register) is done ONCE on
# your machine via a browser; only android_id + security_token are stored (in the DB,
# via /fcm connect — never here). Set to "false" to disable the listener entirely.
FCM_ENABLED=true

# ── Map-marker poller (Phase 8.2) ────────────
# Poll getMapMarkers on each paired server and announce cargo / patrol heli / chinook
# the moment they appear on the map — works on official servers, no plugin/admin. Set
# to "false" to disable. Interval in ms (default 30s); lower = faster alerts, more reqs.
RUSTPLUS_POLL_ENABLED=true
RUSTPLUS_POLL_INTERVAL_MS=30000

# ── Misc ─────────────────────────────────────
NODE_ENV=development
